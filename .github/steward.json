{
  "$schema": "https://raw.githubusercontent.com/splrad/steward/b0f2146e4938b54bea440c92f2139d11d5b37016/schema/steward.schema.json",
  "automation": {
    "githubApp": {
      "clientId": "Iv23liuSr0qd4WLJdZhH",
      "slug": "splrad-steward"
    },
    "language": "zh-CN",
    "maintainers": {
      "source": "organization-team",
      "teamSlug": "maintainers"
    }
  },
  "classification": {
    "areas": [
      {
        "name": "area:workflow",
        "patterns": [
          ".github/workflows/**"
        ]
      },
      {
        "name": "area:docs",
        "patterns": [
          "README.md",
          "docs/**"
        ]
      }
    ],
    "decisions": {
      "kinds": {
        "byConventionalType": [
          {
            "kind": "kind:feature",
            "type": "feat"
          },
          {
            "kind": "kind:docs",
            "type": "docs"
          }
        ],
        "docsOnly": {
          "kind": "kind:docs",
          "pathRules": [
            {
              "files": [
                "README.md"
              ]
            },
            {
              "prefixes": [
                "docs/"
              ]
            },
            {
              "excludePrefixes": [
                ".github/"
              ],
              "suffixes": [
                ".md"
              ]
            }
          ]
        },
        "fallback": "kind:chore"
      },
      "publicLabels": {
        "fallback": "chore",
        "fallbackByKind": [
          {
            "kind": "kind:feature",
            "label": "feature"
          }
        ],
        "rules": [
          {
            "label": "documentation",
            "whenAny": {
              "kinds": [
                "kind:docs"
              ]
            }
          }
        ]
      }
    },
    "installOrPackage": {
      "includeFiles": []
    },
    "labels": {
      "internalPrefixes": [
        "area:",
        "kind:"
      ],
      "public": [
        {
          "color": "1d76db",
          "description": "New E2E Sandbox behavior.",
          "name": "feature"
        },
        {
          "color": "0075ca",
          "description": "E2E Sandbox documentation changes.",
          "name": "documentation"
        },
        {
          "color": "ededed",
          "description": "E2E Sandbox maintenance changes.",
          "name": "chore"
        }
      ],
      "release": [
        "feature"
      ]
    },
    "releaseCategories": [
      {
        "fallback": true,
        "installOrPackage": false,
        "labels": [
          "feature"
        ],
        "releaseLabel": "feature",
        "textPatterns": [],
        "title": "E2E Sandbox changes"
      }
    ],
    "runtimeRelease": {
      "excludeFiles": [
        "README.md"
      ],
      "excludePrefixes": [
        ".github/",
        "docs/"
      ],
      "includeFiles": [],
      "includePrefixes": [
        "src/"
      ]
    }
  },
  "features": {
    "classification": true,
    "copilotReview": true,
    "dcoAdvisory": true,
    "governance": true,
    "prAutomation": true,
    "release": true,
    "webhookRelay": true
  },
  "release": {
    "adapterCommand": [
      "node",
      ".github/steward/release.mjs"
    ],
    "runner": "ubuntu-latest",
    "triggerPaths": [
      "release/version.json"
    ]
  },
  "schemaVersion": 1
}
